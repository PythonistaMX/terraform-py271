project_id                  = "my-gcp-project"
region                      = "us-central1"
environment                 = "test"
app_name                    = "apiflask-demo"
artifact_repository_id      = "apps"
cloud_sql_instance_name     = "apiflask-test-sql"
cloud_sql_database_name     = "apiflask"
cloud_sql_tier              = "db-f1-micro"
db_username                 = "app_user"
enable_deletion_protection  = true
github_repository           = "PythonistaMX/api-github-actions-demo"
cloud_run_service_name      = "apiflask-demo"

# La contraseña de base de datos se pasa como variable de entorno para no
# escribirla en disco. Nunca incluir en terraform.tfvars ni en control de versiones.
# export TF_VAR_db_password="<valor-seguro>"
